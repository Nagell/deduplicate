<Window
    x:Class="Deduplicate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Deduplicate.Views"
    Title="Duplicate Finder">
    <Grid RowDefinitions="32,*">
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">
                <Image Source="Assets/logo.ico" Width="16" Height="16"/>
                <TextBlock
                    Text="Duplicate Finder"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"/>
            </StackPanel>
        </Grid>
        <views:MainPage Grid.Row="1"/>
    </Grid>
</Window>
