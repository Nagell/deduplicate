<Page
    x:Class="Deduplicate.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Deduplicate.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource
            x:Name="GroupedResultsCVS"
            Source="{x:Bind ViewModel.DuplicateGroups, Mode=OneWay}"
            IsSourceGrouped="True"
            ItemsPath="Items"/>
    </Page.Resources>

    <Grid ColumnDefinitions="300,*">

        <!-- ══ Left panel ══ -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Padding="12,12,12,12">

            <!-- Folder picker -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBox
                    Grid.Column="0"
                    PlaceholderText="Select a folder to scan..."
                    Text="{x:Bind ViewModel.FolderPath, Mode=TwoWay}"
                    CornerRadius="4,0,0,4"/>
                <Button
                    Grid.Column="1"
                    Content="Browse"
                    Click="BrowseButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="0,4,4,0"
                    Padding="14,8"/>
            </Grid>

            <!-- Detection Method -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock
                    Text="Detection Method"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,0,0,6"/>
                <RadioButtons
                    x:Name="MethodRadioButtons"
                    SelectedIndex="{x:Bind ViewModel.SelectedMethodIndex, Mode=TwoWay}">
                    <RadioButton Content="Quick – name + size (Recommended)"/>
                    <RadioButton Content="Smart – size then MD5 hash"/>
                    <RadioButton Content="Full Hash – MD5 all files"/>
                </RadioButtons>
            </StackPanel>

            <!-- Include subfolders -->
            <ToggleSwitch
                Grid.Row="2"
                IsOn="{x:Bind ViewModel.IsRecursive, Mode=TwoWay}"
                OnContent="Include subfolders"
                OffContent="Include subfolders"
                Margin="0,0,0,16"/>

            <!-- Scan / Cancel + progress -->
            <StackPanel Grid.Row="3" Spacing="8">
                <Button
                    Content="Scan for Duplicates"
                    Click="ScanButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.CanScan, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"/>
                <StackPanel
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                    Spacing="4">
                    <ProgressBar
                        Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                        IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                        Height="4"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button
                    Content="Cancel"
                    Click="CancelButton_Click"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"/>
            </StackPanel>

            <!-- Row 4: spacer -->

            <!-- Stats card + Delete button (only when results exist) -->
            <StackPanel
                Grid.Row="5"
                Spacing="8"
                Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">

                <TextBlock
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Padding="2,0"/>

                <Button
                    Content="Delete Selected"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                    Click="DeleteSelected_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"/>
            </StackPanel>
        </Grid>

        <!-- ══ Right panel: results ══ -->
        <Border
            Grid.Column="1"
            Margin="0,12,12,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>

            <!-- Initial state -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{x:Bind ViewModel.ShowInitialState, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    Glyph="&#xE8B7;"
                    FontSize="52"
                    Opacity="0.25"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="Select a folder and click Scan to find duplicates."
                    Style="{StaticResource BodyTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"
                    Opacity="0.5"/>
            </StackPanel>

            <!-- No duplicates found -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{x:Bind ViewModel.ShowNoDuplicates, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    Glyph="&#xE930;"
                    FontSize="52"
                    Opacity="0.25"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="No duplicates found."
                    Style="{StaticResource BodyTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"
                    Opacity="0.5"/>
            </StackPanel>

            <!-- Results list -->
            <ListView
                x:Name="ResultsListView"
                ItemsSource="{x:Bind GroupedResultsCVS.View, Mode=OneWay}"
                SelectionMode="None"
                Padding="0,4,0,4"
                Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">

                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="models:DuplicateGroup">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,2,0,2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontFamily="Segoe MDL2 Assets"
                                            Glyph="&#xE8C8;"
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            Opacity="0.7"/>
                                        <TextBlock
                                            Text="{x:Bind GroupLabel}"
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                            VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Grid MinHeight="42" ColumnSpacing="10" Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                Margin="0"/>

                            <FontIcon
                                Grid.Column="1"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE7C3;"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Opacity="0.55"/>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"/>
                                <TextBlock
                                    Text="{x:Bind Directory}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"/>
                            </StackPanel>

                            <TextBlock
                                Grid.Column="3"
                                Text="{x:Bind SizeFormatted}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"/>

                            <TextBlock
                                Grid.Column="4"
                                Text="{x:Bind LastModifiedFormatted}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"/>

                            <StackPanel
                                Grid.Column="5"
                                Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center">
                                <Button
                                    Tag="{x:Bind Path}"
                                    Click="OpenFile_Click"
                                    ToolTipService.ToolTip="Open file with default application"
                                    Padding="10,4">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="12"/>
                                        <TextBlock Text="Open" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button
                                    Tag="{x:Bind Path}"
                                    Click="OpenFolder_Click"
                                    ToolTipService.ToolTip="Show in Explorer"
                                    Padding="10,4">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE838;" FontSize="12"/>
                                        <TextBlock Text="Folder" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
        </Border>

    </Grid>
</Page>
